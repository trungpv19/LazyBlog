{
    "name": "lazyblog/lazyblog",
    "description": "Simple personal blog: PHP + Markdown files, CRT phosphor terminal design.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "league/commonmark": "^2.5",
        "symfony/yaml": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
