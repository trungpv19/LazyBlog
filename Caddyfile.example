# Production Caddyfile for LazyBlog
# -----------------------------------------------------------------------------
# Copy to /etc/caddy/Caddyfile (or import via `import /etc/caddy/sites/*`)
# and replace the placeholders. Caddy handles TLS via Let's Encrypt automatically.
#
# Adjust:
#   * blog.example.com       → your real domain
#   * /var/www/lazyblog      → where you cloned the repo
#   * unix//run/php/php8.2-fpm.sock → check `ls /run/php/*.sock` on your distro
# -----------------------------------------------------------------------------

blog.example.com {
    root * /var/www/lazyblog/public

    encode zstd gzip

    php_fastcgi unix//run/php/php8.2-fpm.sock

    file_server

    # ---- Hardening at the HTTP layer ----

    # Block dotfiles + project metadata so curl /.env returns 404.
    @hidden {
        path /.* /Dockerfile /docker-compose.yml /composer.* /README.md
    }
    respond @hidden 404

    # Strong cache for static assets (CSS/JS/SVG).
    @static path /assets/*
    header @static Cache-Control "public, max-age=2592000, immutable"

    # robots.txt + llms.txt are small and stable enough for an hour of cache.
    @meta path /robots.txt /llms.txt /llms-full.txt
    header @meta Cache-Control "public, max-age=3600"

    # Feed: 5-minute cache matches FeedController's own Cache-Control.
    @feed path /feed.xml
    header @feed Cache-Control "public, max-age=300"

    # Belt-and-braces security headers (PHP layer sets these too — Caddy
    # ensures they're present even if PHP errors out before render).
    header {
        # HSTS — uncomment after you're 100% sure TLS is stable. Once a browser
        # caches HSTS you can't go back to plain HTTP for `max-age` seconds.
        # Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        X-Content-Type-Options       "nosniff"
        X-Frame-Options              "SAMEORIGIN"
        Referrer-Policy              "strict-origin-when-cross-origin"
        Permissions-Policy           "geolocation=(), camera=(), microphone=(), payment=()"

        # Drop the default Server: Caddy banner.
        -Server
    }

    # ---- Optional: simple rate-limit on /admin/login ----
    # Requires Caddy with the rate-limit plugin (xcaddy build --with
    # github.com/mholt/caddy-ratelimit). Without the plugin this block is
    # ignored.
    #
    # @login_post {
    #     path /admin/login
    #     method POST
    # }
    # rate_limit @login_post {
    #     zone login_ip 10r/m
    # }

    log {
        output file /var/log/caddy/lazyblog-access.log {
            roll_size 10mb
            roll_keep 10
        }
        format console
    }
}
