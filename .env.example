# Site
SITE_TITLE="LazyBlog"
SITE_URL="http://localhost:8080"
SITE_DESCRIPTION="A personal blog transmitting thoughts over imperfect radio waves. Expect noise, fading, and low bandwidth—but always authentic signals."
TIMEZONE="Asia/Saigon"

# Default OG/Twitter card image. Used when a post doesn't define `image:`
# in its frontmatter. Can be a path (/uploads/og-default.webp) — gets
# prefixed with SITE_URL — or an absolute https:// URL. Leave empty to
# omit the image tag entirely (link previews fall back to title-only).
# Recommended: 1200×630 px for the cleanest rich-card layout.
SITE_OG_IMAGE=""

# Twitter handle of the site (with @). Emitted as twitter:site so the
# rich Twitter card credits your account. Leave empty to omit.
SITE_TWITTER_HANDLE=""

# Source/repo link shown in the footer "§ SOURCE" block. Defaults to the
# upstream LazyBlog repo for branding/sharing. Point at your fork or
# leave empty to hide the block entirely.
SITE_GITHUB_URL="https://github.com/hieuha/LazyBlog"

# Default CRT theme — "amber" (warm phosphor) or "green" (classic terminal).
# Rendered server-side on <html data-theme> so no-JS visitors get the
# configured choice. Visitors can still flip via the header toggle; their
# pick persists in localStorage and overrides this default on next load.
SITE_DEFAULT_THEME="amber"

# Film-grain / dust overlay on every page. Off = scanlines + vignette only.
# Accepts true / false / on / off / 1 / 0. Default on.
SITE_NOISE="true"

# Default author shown after the date on each post (e.g. § TRANSMISSION — 2026-06-22 — XV5HP).
# Overridden per-post by frontmatter `author:` field.
DEFAULT_AUTHOR="XV5HP"

# Small "callsign" line shown above the site title in the header.
# Free-form — typically HAM_CALLSIGN // STATION // LOCATION.
# Leave empty to hide the line entirely.
CALLSIGN="XV5HP // MAYLAB // HẢI PHÒNG"

# Number of posts per page on home + tag listings.
POSTS_PER_PAGE=10

# Sign-off line shown at the bottom of every page's footer.
# {year} is substituted with the current year so you don't update yearly.
# Leave empty to hide the line entirely.
FOOTER_SIGNOFF="LAZYBLOG TERMINAL // {year} // 73 DE LAZYBLOG"

# Admin (Phase 3)
# Generate hash: docker compose exec app php scripts/hash-password.php yourpassword
ADMIN_PASSWORD_HASH=""

# Session
SESSION_NAME="lazyblog_sess"
SESSION_SECURE="false"   # set true in production (HTTPS)
