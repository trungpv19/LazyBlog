# Site
SITE_TITLE="LazyBlog"
SITE_URL="http://localhost:8080"
SITE_DESCRIPTION="A personal blog on slow scan signals and other transmissions."
TIMEZONE="Asia/Saigon"

# Default author shown after the date on each post (e.g. § TRANSMISSION — 2026-06-22 — XV5HP).
# Overridden per-post by frontmatter `author:` field.
DEFAULT_AUTHOR="XV5HP"

# Admin (Phase 3)
# Generate hash: docker compose exec app php scripts/hash-password.php yourpassword
ADMIN_PASSWORD_HASH=""

# Session
SESSION_NAME="lazyblog_sess"
SESSION_SECURE="false"   # set true in production (HTTPS)
