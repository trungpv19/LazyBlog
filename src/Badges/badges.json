{
  "_": "Default badge catalogue shipped with LazyBlog. Override by copying to content/badges.json. Each entry: code, label, description, kind (one of BadgeKinds::executors()), params (kind-specific). The volume tier is always rendered (locked entries show N/M progress); the hidden tier is only rendered when unlocked, so codes here never leak in HTML until earned.",

  "volume": [
    { "code": "FIRST-TX",        "label": "FIRST TX",          "description": "Send the first transmission",          "kind": "post-count",           "params": { "threshold": 1 } },
    { "code": "BROADCAST-X10",   "label": "BROADCAST ×10",     "description": "10 published transmissions",          "kind": "post-count",           "params": { "threshold": 10 } },
    { "code": "BROADCAST-X50",   "label": "BROADCAST ×50",     "description": "50 published transmissions",          "kind": "post-count",           "params": { "threshold": 50 } },
    { "code": "BROADCAST-X100",  "label": "BROADCAST ×100",    "description": "100 published transmissions",         "kind": "post-count",           "params": { "threshold": 100 } },
    { "code": "LONG-FORM",       "label": "LONG-FORM OPERATOR","description": "1 transmission ≥ 5000 words",         "kind": "longest-post-words",   "params": { "threshold": 5000 } },
    { "code": "SERIES-INIT",     "label": "SERIES INITIATED",  "description": "First series with ≥3 published parts","kind": "series-min-parts",     "params": { "threshold": 3 } },
    { "code": "TAG-SPECIALIST",  "label": "TAG SPECIALIST",    "description": "≥10 posts in a single tag",           "kind": "tag-count",            "params": { "threshold": 10 } },
    { "code": "ONE-YEAR-ONLINE", "label": "ONE YEAR ONLINE",   "description": "Blog age ≥ 365 days",                 "kind": "blog-age-days",        "params": { "threshold": 365 } },
    { "code": "IRON-STREAK",     "label": "IRON STREAK (12w)", "description": "Longest weekly streak ≥ 12 weeks",    "kind": "longest-streak-weeks", "params": { "threshold": 12 } },
    { "code": "MARATHON",        "label": "MARATHON (26w)",    "description": "Longest weekly streak ≥ 26 weeks",    "kind": "longest-streak-weeks", "params": { "threshold": 26 } }
  ],

  "hidden": [
    { "code": "NIGHT-OWL",       "label": "NIGHT OWL",         "description": "Transmission between 00:00 and 04:00","kind": "time-window",          "params": { "hourFrom": 0,  "hourTo": 4 } },
    { "code": "FRIDAY-NIGHT-TX", "label": "FRIDAY NIGHT TX",   "description": "Friday transmission after 20:00",     "kind": "time-window",          "params": { "hourFrom": 20, "hourTo": 24, "dayOfWeek": 5 } },
    { "code": "COMEBACK",        "label": "COMEBACK",          "description": "Transmission after ≥ 30 days silent", "kind": "gap-days",             "params": { "threshold": 30 } },
    { "code": "DOUBLE-TAP",      "label": "DOUBLE TAP",        "description": "2 transmissions on a single day",     "kind": "same-day-count",       "params": { "threshold": 2 } },
    { "code": "TRIPLE-TAP",      "label": "TRIPLE TAP",        "description": "3 transmissions on a single day",     "kind": "same-day-count",       "params": { "threshold": 3 } },
    { "code": "BIRTHDAY-TX",     "label": "BIRTHDAY TX",       "description": "Transmission on the blog anniversary","kind": "anniversary",          "params": {} },
    { "code": "LEAP-YEAR",       "label": "LEAP YEAR TX",      "description": "Transmission on Feb 29",              "kind": "date-suffix",          "params": { "mmDd": "-02-29" } },
    { "code": "NEW-YEAR-TX",     "label": "NEW YEAR TX",       "description": "Transmission on Jan 1",               "kind": "date-suffix",          "params": { "mmDd": "-01-01" } }
  ]
}
