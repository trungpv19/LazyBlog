:8080 {
    root * /var/www/html/public
    encode gzip

    php_fastcgi app:9000

    file_server

    # Block dotfiles
    @hidden path_regexp ^/\.
    respond @hidden 404

    # Block direct .env or .md request to project root
    @blocked path /Dockerfile /docker-compose.yml /.env*
    respond @blocked 404

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output stdout
        format console
    }
}
